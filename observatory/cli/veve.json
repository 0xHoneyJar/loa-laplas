  ],
  "ladder": {
    "level": 1,
    "promoted_from": "grimoires/loa/observatory/{sim-gen,trace-gen,serve}.mjs (session scripts)",
    "evidence_runs": [
      "run:obs-panel-20260611:valid_run",
      "run:sim-seed-7:gradient-divergence-proof"
    ]
  },
  "liveness": {
    "timeout_s": 30,
    "expected_p95_s": 2,
    "mode": "oneshot"
  }
