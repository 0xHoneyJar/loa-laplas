{
  "veve_version": "0.2.0",
  "name": "obs",
  "version": "0.1.0",
  "summary": "Observatory CLI: sim (seeded gradient forward-model, golden-vectored), fold (real compose run -> obs-level/1), serve (live tail). Classed by worst case; vectors pin the deterministic subset.",
  "binary": {
    "entry": "obs.mjs",
    "runtime": "node",
    "subcommands": ["sim", "fold", "serve", "selftest"]
  },
  "determinism": {
    "class": "attestable",
    "declared_by": "author",
    "ambient": ["filesystem_outside_cwd", "clock", "network"]
  },
  "io": {
    "input": "argv",
    "output": "stdout_json",
    "exit_codes": {
      "0": "ok",
      "1": "tool failure",
      "2": "contract violation or unknown verb (caller error)"
    }
  },
  "vectors": [
