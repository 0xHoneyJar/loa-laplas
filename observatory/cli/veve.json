      "expect_exit": 0
    },
    {
      "name": "sim-disciplined-ships",
      "argv": ["sim", "--seed", "7", "--greed", ".2", "--discipline", ".9", "--rooms", "6"],
      "stdin": "",
      "expect_output_hash": "sha256:467151bbf804e2b88d3bd8de171c6dc84eb665593bd55541e93a7038928af1b4",
      "expect_exit": 0
    },
    {
      "name": "sim-default-seed-42",
      "argv": ["sim", "--seed", "42"],
      "stdin": "",
      "expect_output_hash": "sha256:821e715b5e97ef4be704d705cf8c78db0d3c11cdecfce316280245330d6f8b38",
      "expect_exit": 0
