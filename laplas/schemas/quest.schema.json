{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://loa-hounfour/laplas/quest/1",
  "title": "Quest — the WHAT (objectives, task literals, gate contracts, mandated reads)",
  "type": "object",
  "required": ["name", "version"],
  "additionalProperties": true,
  "properties": {
    "name": { "type": "string", "minLength": 1, "maxLength": 64 },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "rel": { "type": "string", "enum": ["competitive", "cooperative", "solo"] },
    "objectives": {
      "type": "array",
      "description": "Task literals — the SAME text the dispatcher seeds as run_state.task and the emitter bakes into work+gate prompts. Bounded so a malformed quest cannot inject structural directives into the gate prompt (T5/U1).",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 4000,
        "not": { "pattern": "```" }
      }
    },
    "requires": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "roles": { "type": "array", "items": { "type": "string" } },
        "tools": { "type": "array", "items": { "type": "string" } }
      }
    },
    "review_routing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "council": { "type": "boolean" },
        "min_voices": { "type": "integer", "minimum": 2 }
      }
    },
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "room"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "room": { "type": "string" },
          "hitl": { "type": "string" }
        }
      }
    },
    "mandated_reads": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "h1"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "h1": { "type": "string", "minLength": 1, "maxLength": 200 }
        }
      }
    }
  }
}
